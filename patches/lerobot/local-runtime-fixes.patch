+class AsyncRerunLogger:
+    """Send live display frames without blocking the record/control loop."""
+
+    def __init__(self, compress_images: bool):
+        self.compress_images = compress_images
+        self._queue: queue.Queue = queue.Queue(maxsize=1)
+        self._stop_event = threading.Event()
+        self._thread = threading.Thread(target=self._run, name="rerun-display", daemon=True)
+        self._dropped_frames = 0
+
+    def start(self) -> None:
+        self._thread.start()
+
+    def submit(self, observation: RobotObservation, action: RobotAction | None) -> None:
+        item = (dict(observation), dict(action) if action is not None else None)
+        while True:
+            try:
+                self._queue.put_nowait(item)
+                return
+            except queue.Full:
+                try:
+                    self._queue.get_nowait()
+                    self._queue.task_done()
+                    self._dropped_frames += 1
+                except queue.Empty:
+                    pass
+
+    def close(self) -> None:
+        self._stop_event.set()
+        self._thread.join(timeout=2.0)
+        if self._dropped_frames:
+            logging.info("Dropped %s live-display frame(s) to keep recording non-blocking.", self._dropped_frames)
+
+    def _run(self) -> None:
+        while not self._stop_event.is_set() or not self._queue.empty():
+            try:
+                observation, action = self._queue.get(timeout=0.1)
+            except queue.Empty:
+                continue
+
+            try:
+                log_rerun_data(
+                    observation=observation,
+                    action=action,
+                    compress_images=self.compress_images,
+                )
+            except Exception:
+                logging.exception("Live Rerun display logging failed.")
+            finally:
+                self._queue.task_done()
+
+
+def _flush_pending_stdin() -> None:
+    if not sys.stdin.isatty():
+        return
+
+    while True:
+        ready, _, _ = select.select([sys.stdin], [], [], 0)
+        if not ready:
+            return
+        sys.stdin.readline()
+
+
+def _confirm_episode_start(recorded_episodes: int, target_episodes: int, dataset_episode_index: int) -> bool:
+    if not sys.stdin.isatty():
+        logging.warning("manual_episode_start requested but stdin is not interactive; continuing automatically.")
+        return True
+
+    _flush_pending_stdin()
+    answer = input(
+        f"Press Enter to record episode {recorded_episodes + 1}/{target_episodes} "
+        f"(dataset index {dataset_episode_index}), or type q then Enter to stop: "
+    )
+    return answer.strip().lower() not in {"q", "quit", "exit", "stop"}
+
