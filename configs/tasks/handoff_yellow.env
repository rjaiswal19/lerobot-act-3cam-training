# Zero-shot task values for handing off the yellow beaker.

TASK_SLUG="handoff_yellow"
DATASET_NAME_TEMPLATE="seeed_3cam_{task}_training"
POLICY_NAME_TEMPLATE="{policy}_seeed_3cam_{task}"
TASK_DESCRIPTION="Pick up the yellow beaker and place it on the back-left corner of the white pad from the robot's perspective"
TRAIN_OUTPUT_DIR_TEMPLATE="outputs/train/{policy}_seeed_3cam_{task}"
JOB_NAME_TEMPLATE="{policy}_seeed_3cam_{task}"
