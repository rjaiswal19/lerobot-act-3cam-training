# Pi0.5 base zero-shot handoff defaults.
#
# These settings are intentionally conservative. Pi0.5 base has not been
# fine-tuned for the B601 arm, so the physical zero-shot scripts refuse to
# execute this base checkpoint. Use this config for no-motion plumbing checks
# or replace ZERO_SHOT_POLICY_PATH with a B601-compatible checkpoint.

ZERO_SHOT_POLICY_PATH="lerobot/pi05_base"
ZERO_SHOT_FPS=1
ZERO_SHOT_DURATION_S=6
ZERO_SHOT_RETURN_TO_INITIAL_POSITION=true

# Map this workspace's camera names to the generic camera names expected by
# lerobot/pi05_base.
ZERO_SHOT_RENAME_MAP='{"observation.images.zed_left":"observation.images.base_0_rgb","observation.images.wrist":"observation.images.left_wrist_0_rgb","observation.images.zed_right":"observation.images.right_wrist_0_rgb"}'
