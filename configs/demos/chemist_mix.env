# Autonomous chemist demo defaults.
#
# This demo composes trained Pi0.5 short-horizon policies; it does not ask an
# LLM to produce joint targets. The planner may only choose from the skill IDs
# listed in scripts/chemist_llm_planner.py.

CHEMIST_GOAL="Mix the liquid from the blue beaker and yellow beaker into the green beaker, then swirl the green beaker."
CHEMIST_POLICY_TYPE="pi05"

# auto: use an LLM when OPENAI_API_KEY is present, otherwise use the fixed safe
# single-arm plan. Use "llm" to require the LLM planner, or "fixed" to disable it.
CHEMIST_PLANNER_MODE="auto"
CHEMIST_LLM_MODEL="gpt-4.1-mini"

# Manual verification is the safest default for first physical trials. Set to
# "none" only for bench/dry-run tests where every skill should advance.
CHEMIST_VERIFY_MODE="manual"
CHEMIST_MAX_RETRIES=1
CHEMIST_CONFIRM_BEFORE_EXECUTION=true

# Short skill rollout timing. Override per run if the policy needs more time.
CHEMIST_ROLLOUT_FPS=5
CHEMIST_POUR_DURATION_S=35
CHEMIST_SWIRL_DURATION_S=25

# Deployment defaults for Pi0.5 / RTC. These can be overridden from the shell.
CHEMIST_ROLLOUT_INFERENCE_TYPE="rtc"
CHEMIST_RTC_EXECUTION_HORIZON=10
CHEMIST_RTC_MAX_GUIDANCE_WEIGHT=10.0
CHEMIST_RTC_QUEUE_THRESHOLD=30
CHEMIST_RETURN_TO_INITIAL_POSITION=true
