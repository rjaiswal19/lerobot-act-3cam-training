# Local LeRobot shared config.
# This file is only for hardware/runtime defaults used by every task.
# Task-specific dataset names, policy names, task text, output dirs, and job
# names live in configs/tasks/*.env.

# Hugging Face owner.
# Prefer putting this in .env:
#   HF_USER_OR_ORG="your_hf_username_or_org"

# Robot and teleoperation setup.
# Seeed reBot Arm B601-DM follower with Damiao serial bridge.
ROBOT_TYPE="seeed_b601_dm_follower"
ROBOT_PORT="/dev/ttyACM0"
ROBOT_ID="follower1"
ROBOT_CAN_ADAPTER="damiao"

TELEOP_TYPE="rebot_arm_102_leader"
TELEOP_PORT="/dev/ttyUSB0"
TELEOP_ID="rebot_arm_102_leader"
TELEOP_JOINT_DIRECTIONS='{"shoulder_pan":-1,"shoulder_lift":-1,"elbow_flex":1,"wrist_flex":1,"wrist_yaw":1,"wrist_roll":-1,"gripper":-4}'

# RGB camera setup.
# Run `bash scripts/find_cameras.sh`, then update these IDs.
# Shared defaults. Per-camera values below can override these.
CAMERA_WIDTH=640
CAMERA_HEIGHT=480
CAMERA_FPS=30

WRIST_CAMERA_TYPE=opencv
WRIST_CAMERA_INDEX=1
WRIST_CAMERA_WIDTH="$CAMERA_WIDTH"
WRIST_CAMERA_HEIGHT="$CAMERA_HEIGHT"
WRIST_CAMERA_FPS="$CAMERA_FPS"

# ZED X GMSL cameras must be read through the ZED SDK. The raw
# /dev/video0 and /dev/video3 V4L nodes return green dummy frames here.
ZED_CAMERA_TYPE=zed_sdk
ZED_CAMERA_SERIAL_NUMBER=42258215
ZED_CAMERA_RESOLUTION=HD1200
ZED_CAMERA_DEPTH_MODE=NONE
ZED_CAMERA_TIMEOUT_MS=2000
ZED_CAMERA_WARMUP_S=0.5
ZED_CAMERA_WIDTH=1920
ZED_CAMERA_HEIGHT=1200

ZED_LEFT_CAMERA_TYPE="$ZED_CAMERA_TYPE"
ZED_LEFT_CAMERA_SIDE=left
ZED_LEFT_CAMERA_WIDTH="$ZED_CAMERA_WIDTH"
ZED_LEFT_CAMERA_HEIGHT="$ZED_CAMERA_HEIGHT"
ZED_LEFT_CAMERA_FPS="$CAMERA_FPS"

ZED_RIGHT_CAMERA_TYPE="$ZED_CAMERA_TYPE"
ZED_RIGHT_CAMERA_SIDE=right
ZED_RIGHT_CAMERA_WIDTH="$ZED_CAMERA_WIDTH"
ZED_RIGHT_CAMERA_HEIGHT="$ZED_CAMERA_HEIGHT"
ZED_RIGHT_CAMERA_FPS="$CAMERA_FPS"

# Dataset collection defaults.
NUM_EPISODES=50
DATASET_FPS=5
EPISODE_TIME_S=60
RESET_TIME_S=20
DISPLAY_DATA=true
STREAMING_ENCODING=true
ENCODER_THREADS=2
PUSH_TO_HUB=false
RECORD_RESUME=false

# Policy/training.
# Change this to another LeRobot policy type, for example "pi0" or "pi05",
# after confirming the policy is installed/supported by your LeRobot version.
POLICY_TYPE="act"

# Use "cuda" for the default visible NVIDIA GPU, "cuda:0" / "cuda:1" to pin
# a GPU, "mps" on Apple Silicon, or "cpu" for debugging only.
POLICY_DEVICE="cuda"
WANDB_ENABLE=false
POLICY_PUSH_TO_HUB=true
POLICY_PRIVATE=false
