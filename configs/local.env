# Local LeRobot shared config.
# This file is only for hardware/runtime defaults used by every task.
# Task-specific dataset names, policy names, task text, output dirs, and job
# names live in configs/tasks/*.env.

# Hugging Face owner.
# Prefer putting this in .env:
#   HF_USER_OR_ORG="your_hf_username_or_org"

# Robot and teleoperation setup.
# For Seeed Studio SO-101, these defaults are usually correct.
ROBOT_TYPE="so101_follower"
ROBOT_PORT="CHANGE_ME_FOLLOWER_SERIAL_PORT"
ROBOT_ID="seeed_follower_01"

TELEOP_TYPE="so101_leader"
TELEOP_PORT="CHANGE_ME_LEADER_SERIAL_PORT"
TELEOP_ID="seeed_leader_01"

# RGB camera setup.
# Run `bash scripts/find_cameras.sh`, then update these IDs.
# Shared defaults. Per-camera values below can override these.
CAMERA_WIDTH=640
CAMERA_HEIGHT=480
CAMERA_FPS=30

WRIST_CAMERA_INDEX=0
WRIST_CAMERA_WIDTH="$CAMERA_WIDTH"
WRIST_CAMERA_HEIGHT="$CAMERA_HEIGHT"
WRIST_CAMERA_FPS="$CAMERA_FPS"

ZED_LEFT_CAMERA_INDEX=1
ZED_LEFT_CAMERA_WIDTH="$CAMERA_WIDTH"
ZED_LEFT_CAMERA_HEIGHT="$CAMERA_HEIGHT"
ZED_LEFT_CAMERA_FPS="$CAMERA_FPS"

ZED_RIGHT_CAMERA_INDEX=2
ZED_RIGHT_CAMERA_WIDTH="$CAMERA_WIDTH"
ZED_RIGHT_CAMERA_HEIGHT="$CAMERA_HEIGHT"
ZED_RIGHT_CAMERA_FPS="$CAMERA_FPS"

# Dataset collection defaults.
NUM_EPISODES=50
EPISODE_TIME_S=60
RESET_TIME_S=20
DISPLAY_DATA=true
STREAMING_ENCODING=true
ENCODER_THREADS=2
PUSH_TO_HUB=true
RECORD_RESUME=false

# Policy/training.
# Change this to another LeRobot policy type, for example "pi0" or "pi05",
# after confirming the policy is installed/supported by your LeRobot version.
POLICY_TYPE="act"

# Use "cuda" for the default visible NVIDIA GPU, "cuda:0" / "cuda:1" to pin
# a GPU, "mps" on Apple Silicon, or "cpu" for debugging only.
POLICY_DEVICE="cuda"
WANDB_ENABLE=false
POLICY_PUSH_TO_HUB=true
POLICY_PRIVATE=false
