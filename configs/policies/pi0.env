# Popular Pi0 finetuning defaults from LeRobot docs.
# Requires installing LeRobot with Pi dependencies on the training machine:
#   pip install -e ".[pi]"

TRAIN_STEPS=3000
TRAIN_BATCH_SIZE=32

POLICY_PRETRAINED_PATH="lerobot/pi0_base"
POLICY_COMPILE_MODEL=true
POLICY_GRADIENT_CHECKPOINTING=true
POLICY_DTYPE="bfloat16"
POLICY_FREEZE_VISION_ENCODER=false
POLICY_TRAIN_EXPERT_ONLY=false

# Optional PEFT/LoRA. Leave PEFT_METHOD_TYPE empty for normal finetuning.
# To train LoRA adapters instead, set:
#   PEFT_METHOD_TYPE="LORA"
#   PEFT_R=64
PEFT_METHOD_TYPE=""
PEFT_R=64
PEFT_TARGET_MODULES=""
PEFT_FULL_TRAINING_MODULES=""

# Optional relative-action settings. Leave empty unless you recompute dataset
# stats for relative actions first.
POLICY_USE_RELATIVE_ACTIONS=""
POLICY_RELATIVE_EXCLUDE_JOINTS=""

# Keep empty unless you need to pass extra LeRobot CLI flags.
POLICY_EXTRA_ARGS=()
