# Popular ACT defaults for small real-robot imitation learning runs.
# ACT is lightweight and included in base LeRobot.

TRAIN_STEPS=50000
TRAIN_BATCH_SIZE=8

# ACT normally trains from scratch, so no pretrained path is set.
POLICY_PRETRAINED_PATH=""

# Action chunking. `n_action_steps` must be <= `chunk_size`.
# A common ACT default is 100/100. For more frequent replanning, try
# chunk_size=100 with n_action_steps=50, or enable temporal ensembling below.
POLICY_N_OBS_STEPS=1
POLICY_CHUNK_SIZE=100
POLICY_N_ACTION_STEPS=100

# Vision backbone.
POLICY_VISION_BACKBONE="resnet18"
POLICY_PRETRAINED_BACKBONE_WEIGHTS="ResNet18_Weights.IMAGENET1K_V1"
POLICY_REPLACE_FINAL_STRIDE_WITH_DILATION=false

# Transformer / VAE defaults.
POLICY_DIM_MODEL=512
POLICY_N_HEADS=8
POLICY_DIM_FEEDFORWARD=3200
POLICY_N_ENCODER_LAYERS=4
POLICY_N_DECODER_LAYERS=1
POLICY_USE_VAE=true
POLICY_LATENT_DIM=32
POLICY_N_VAE_ENCODER_LAYERS=4
POLICY_DROPOUT=0.1
POLICY_KL_WEIGHT=10.0

# Inference behavior. Leave empty to use chunk queueing. If set to 0.01 for
# temporal ensembling, `POLICY_N_ACTION_STEPS` must be 1.
POLICY_TEMPORAL_ENSEMBLE_COEFF=""

# Optimization defaults from ACT config.
POLICY_OPTIMIZER_LR=0.00001
POLICY_OPTIMIZER_WEIGHT_DECAY=0.0001
POLICY_OPTIMIZER_LR_BACKBONE=0.00001

# Keep empty unless you need to pass extra LeRobot CLI flags.
POLICY_EXTRA_ARGS=()
