# Popular Pi0.5 finetuning defaults from LeRobot docs.
# Requires installing LeRobot with Pi dependencies on the training machine:
#   pip install -e ".[pi]"

TRAIN_STEPS=3000
TRAIN_BATCH_SIZE=32

POLICY_PRETRAINED_PATH="lerobot/pi05_base"
POLICY_COMPILE_MODEL=true
POLICY_GRADIENT_CHECKPOINTING=true
POLICY_DTYPE="bfloat16"
POLICY_FREEZE_VISION_ENCODER=false
POLICY_TRAIN_EXPERT_ONLY=false

# Optional PEFT/LoRA. Leave PEFT_METHOD_TYPE empty for normal finetuning.
# To train LoRA adapters instead, set:
#   PEFT_METHOD_TYPE="LORA"
#   PEFT_R=64
PEFT_METHOD_TYPE=""
PEFT_R=64
PEFT_TARGET_MODULES=""
PEFT_FULL_TRAINING_MODULES=""

# Pi0.5 docs recommend this when the dataset has not been converted with
# quantile stats.
POLICY_NORMALIZATION_MAPPING='{"ACTION":"MEAN_STD","STATE":"MEAN_STD","VISUAL":"IDENTITY"}'

# Optional relative-action settings. Leave empty unless you recompute dataset
# stats for relative actions first.
POLICY_USE_RELATIVE_ACTIONS=""
POLICY_RELATIVE_EXCLUDE_JOINTS=""

# Keep empty unless you need to pass extra LeRobot CLI flags.
POLICY_EXTRA_ARGS=()

# Pi0.5 is slow enough that deployment should use LeRobot RTC by default.
# The chemist demo executes short skill rollouts and replans after each
# verified subtask.
ROLLOUT_INFERENCE_TYPE="rtc"
ROLLOUT_RTC_EXECUTION_HORIZON=10
ROLLOUT_RTC_MAX_GUIDANCE_WEIGHT=10.0
ROLLOUT_RTC_QUEUE_THRESHOLD=30
ROLLOUT_USE_TORCH_COMPILE=false
ROLLOUT_EXTRA_ARGS=()
